-- Traits with method signatures
pub trait Eq a where { val eq: &a -> &a -> Bool }
pub trait Ord a where Eq a where { val compare: &a -> &a -> Ordering }
pub trait Hash a where Eq a where { val hash: &a -> Int }
pub trait Clone a where { val clone: &a -> a }
pub trait Copy a where Clone a
pub trait Drop a where { val drop: a -> Unit }
pub trait Sized a
pub trait Add a where { val add: a -> a -> a }
pub trait Sub a where { val sub: a -> a -> a }
pub trait Mul a where { val mul: a -> a -> a }
pub trait Div a where { val div: a -> a -> Result a DivisionByZero }
pub trait Rem a where { val rem: a -> a -> Result a DivisionByZero }
pub trait Neg a where { val neg: a -> a }

