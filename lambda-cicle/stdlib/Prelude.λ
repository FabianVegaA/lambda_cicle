-- Std.Prelude - Auto-imported prelude
-- Layer 0 (no dependencies)

-- Types and Constructors (§16.2)
pub type Bool (..)
pub type Unit (..)
pub type Option a (..)
pub type Result a e (..)
pub type Ordering (..)
pub type DivisionByZero (..)

-- Boolean logic functions (§16.2)
pub val not : Bool -> Bool = \x : Bool. match x with { false -> true | true -> false }
pub val and : Bool -> Bool -> Bool = \x : Bool. \y : Bool. match x with { true -> y | false -> false }
pub val or : Bool -> Bool -> Bool = \x : Bool. \y : Bool. match x with { true -> true | false -> y }

-- Effect abstraction traits (§16.2)
pub trait Functor f where
    val fmap : (a -> b) -> f a -> f b

pub trait Applicative f where Functor f where
    val pure : a -> f a
    val apply : f (a -> b) -> f a -> f b

pub trait Monad m where Applicative m where
    val bind : m a -> (a -> m b) -> m b
    val then : m a -> m b -> m b = \x : m a. \y : m b. bind x (\_:a. y)

-- Traits with method signatures
pub trait Eq a where
    val eq : &a -> &a -> Bool
    val neq : &a -> &a -> Bool = \x : &a. \y : &a. not (eq x y)

pub trait Ord a where Eq a where
    val compare : &a -> &a -> Ordering
    val lt : &a -> &a -> Bool = \x : &a. \y : &a. prim_ilt x y
    val gt : &a -> &a -> Bool = \x : &a. \y : &a. prim_igt x y
    val lte : &a -> &a -> Bool = \x : &a. \y : &a. prim_ile x y
    val gte : &a -> &a -> Bool = \x : &a. \y : &a. prim_ige x y

pub trait Hash a where Eq a where
    val hash : &a -> Int

pub trait Clone a where
    val clone : &a -> a

pub trait Copy a where Clone a

pub trait Drop a where
    val drop : a -> Unit

pub trait Sized a

pub trait Add a where
    val add : a -> a -> a

pub trait Sub a where
    val sub : a -> a -> a

pub trait Mul a where
    val mul : a -> a -> a

pub trait Div a where
    val div : a -> a -> Result a DivisionByZero

pub trait Rem a where
    val rem : a -> a -> Result a DivisionByZero

pub trait Neg a where
    val neg : a -> a

-- Option instances
impl Eq for (Option a) where Eq a with eq = \x : &(Option a). \y : &(Option a).
    match x with { None -> match y with { None -> true | Some _ -> false } | Some xv ->
        match y with { None -> false | Some yv -> eq xv yv } }

impl Clone for (Option a) where Clone a with clone = \x : &(Option a).
    match x with { None -> None | Some v -> Some (clone v) }

impl Functor for Option with fmap = \f : a -> b. \opt : Option a.
    match opt with { None -> None | Some x -> Some (f x) }

impl Applicative for Option with
    pure = \x : a. Some x
    apply = \mf : Option (a -> b). \mx : Option a.
        match mf with { None -> None | Some f ->
            match mx with { None -> None | Some x -> Some (f x) } }

impl Monad for Option with
    bind = \m : Option a. \f : a -> Option b.
        match m with { None -> None | Some x -> f x }

-- Result instances
impl Eq for (Result a e) where Eq a, Eq e with eq = \x : &(Result a e). \y : &(Result a e).
    match x with { Err ex -> match y with { Err ey -> eq ex ey | Ok _ -> false } | Ok xv ->
        match y with { Err _ -> false | Ok yv -> eq xv yv } }

impl Clone for (Result a e) where Clone a, Clone e with clone = \x : &(Result a e).
    match x with { Err e -> Err (clone e) | Ok v -> Ok (clone v) }

impl Functor for (Result a) with fmap = \f : a -> b. \r : Result a e.
    match r with { Err e -> Err e | Ok x -> Ok (f x) }

impl Applicative for (Result a) with
    pure = \x : a. Ok x
    apply = \rf : Result (a -> b) e. \rx : Result a e.
        match rf with { Err e -> Err e | Ok f ->
            match rx with { Err e -> Err e | Ok x -> Ok (f x) } }

impl Monad for (Result a) with
    bind = \m : Result a e. \f : a -> Result b e.
        match m with { Err e -> Err e | Ok x -> f x }

