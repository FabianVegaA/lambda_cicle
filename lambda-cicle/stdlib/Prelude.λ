-- Std.Prelude - Auto-imported prelude
-- Layer 0 (no dependencies)

-- Native type stubs (§9.1) — Int, Float, Char are compiler primitives;
-- these declarations make them visible as nominal types in the AST.
pub type Int (..)
pub type Float (..)
pub type Char (..)

-- ADT types (§16.2)
pub type Bool (..) = True | False
pub type Unit (..)

-- Traits
pub trait Eq a where
    val eq : &a -> &a -> Bool

pub trait Ord a where Eq a
    val compare : &a -> &a -> Bool
    val lt : &a -> &a -> Bool
    val gt : &a -> &a -> Bool

-- Implementations
impl Eq for Bool with eq = \x : &Bool. \y : &Bool. True
impl Eq for Int with eq = \x : &Int. \y : &Int. True
impl Ord for Int with compare = \x : &Int. \y : &Int. True
